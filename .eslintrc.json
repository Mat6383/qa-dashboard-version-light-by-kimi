{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["error", "warn"] }]
  },
  "overrides": [
    {
      "files": ["backend/**/*.js"],
      "env": {
        "browser": false,
        "node": true,
        "commonjs": true
      },
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["backend/tests/**/*.js"],
      "env": {
        "jest": true,
        "node": true
      }
    }
  ]
}
