# ── Server ──────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
DB_DATA_DIR=./db-data

# ── Testmo ──────────────────────────────────────────────
TESTMO_URL=https://your-instance.testmo.net
TESTMO_TOKEN=your_token_here

# ── GitLab ──────────────────────────────────────────────
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxx
GITLAB_WRITE_TOKEN=glpat-yyy
GITLAB_PROJECT_ID=12345678
GITLAB_VERIFY_SSL=true
GITLAB_CLIENT_ID=your_app_id
GITLAB_CLIENT_SECRET=your_app_secret

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars
ADMIN_API_TOKEN=admin-secret-token

# ── Rate limits ─────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_HEAVY_MAX=20

# ── Cache / Perf ────────────────────────────────────────
CACHE_DURATION=300
API_TIMEOUT=30.0

# ── SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=secret
SMTP_FROM=QA Dashboard <alerts@example.com>

# ── Sentry ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Audit / Alerts ──────────────────────────────────────
AUDIT_RETENTION_DAYS=90
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_MEMORY_THRESHOLD=0.85
ALERT_DISK_THRESHOLD=0.90

# ── Backup ──────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_LOCAL_RETENTION_DAYS=7
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_ENDPOINT=
BACKUP_S3_RETENTION_DAYS=30
BACKUP_RSYNC_ENABLED=false
BACKUP_RSYNC_HOST=
BACKUP_RSYNC_USER=
BACKUP_RSYNC_PATH=
BACKUP_RSYNC_SSH_KEY=
BACKUP_RSYNC_PORT=22
BACKUP_RSYNC_RETENTION_DAYS=30

# ── PDF ─────────────────────────────────────────────────
PDF_POOL_SIZE=5
PDF_MAX_PAGE_GENERATIONS=1000
PDF_MAX_CONCURRENCY=3
PDF_MAX_QUEUE_SIZE=50
PDF_IDLE_TIMEOUT_MS=300000
PDF_PAGE_TIMEOUT_MS=30000

# ── Auto Sync ───────────────────────────────────────────
SYNC_TIMEZONE=Europe/Paris
SYNC_AUTO_ENABLED=false
SYNC_AUTO_RUN_ID=
SYNC_AUTO_ITERATION_NAME=
SYNC_AUTO_GITLAB_PROJECT_ID=
SYNC_AUTO_VERSION=
