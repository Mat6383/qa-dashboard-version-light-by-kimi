# ==========================================
# TESTMO DASHBOARD - Configuration Frontend
# ==========================================
# Copier ce fichier en .env et adapter les valeurs

# URL de l'API backend — changer pour pointer vers votre serveur
# Dev local (backend Python) : http://localhost:3001/api
# Dev local (backend Node.js legacy) : http://localhost:3001/api
# Production : https://mon-serveur.com/api
VITE_API_URL=http://localhost:3001/api

# URL du backend sans /api (utilisé par le proxy Vite en dev uniquement)
# Doit pointer vers le serveur qui expose /trpc et /api
BACKEND_URL=http://localhost:3001
