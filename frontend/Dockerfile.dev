# syntax=docker/dockerfile:1
# ───────────────────────────────────────────────────────────────────────────────
# Frontend — Image de développement (hot-reload Vite)
# ───────────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim

WORKDIR /app

ENV NODE_ENV=development

# Installation des dépendances npm
COPY package*.json ./
RUN npm install

# Le code source est monté par bind mount en dev
CMD ["npm", "run", "dev"]
