# ==========================================
# TESTMO DASHBOARD - Configuration Backend
# ==========================================
# ⚠️ IMPORTANT: Copier ce fichier en .env et remplir les valeurs réelles
# ⚠️ NE JAMAIS COMMITER le fichier .env dans Git !
# ⚠️ Variables marquées [REQUIS] → le serveur refuse de démarrer si absentes

# ==========================================
# Testmo API — [REQUIS]
# ==========================================
TESTMO_URL=https://votre-instance.testmo.net
TESTMO_TOKEN=testmo_api_VOTRE_TOKEN_ICI

# ==========================================
# GitLab API — [REQUIS]
# ==========================================
GITLAB_URL=https://gitlab.votre-instance.fr
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx          # Token lecture (scope: read_api)
GITLAB_WRITE_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx    # Token écriture (scope: api) — peut être identique à GITLAB_TOKEN
GITLAB_PROJECT_ID=63
GITLAB_LABEL=Test::TODO
GITLAB_VERIFY_SSL=true                           # Mettre false uniquement pour GitLab self-hosted avec certificat auto-signé

# ==========================================
# GitLab Native Status (GitLab 17+ Work Items)
# Valeurs GID découvertes via l'API GraphQL
# ==========================================
GITLAB_STATUS_TODO=gid://gitlab/WorkItems::Statuses::Custom::Status/15
GITLAB_STATUS_OK=gid://gitlab/WorkItems::Statuses::Custom::Status/18
GITLAB_STATUS_KO=gid://gitlab/WorkItems::Statuses::Custom::Status/17
GITLAB_STATUS_WIP=gid://gitlab/WorkItems::Statuses::Custom::Status/21
GITLAB_STATUS_RETEST=gid://gitlab/WorkItems::Statuses::Custom::Status/19
GITLAB_VERSION_FIELD_ID=gid://gitlab/Issuables::CustomField/1

# ==========================================
# CrossTest Dashboard 7
# ==========================================
CROSSTEST_PROJECT_ID=63                           # ID du projet GitLab pour le CrossTest

# ==========================================
# Serveur
# ==========================================
PORT=3001
NODE_ENV=development                             # development | production

# ==========================================
# CORS — Autoriser le(s) frontend(s)
# Valeur unique :   FRONTEND_URL=http://localhost:3000
# Multi-origines :  FRONTEND_URL=http://localhost:3000,https://dashboard.exemple.fr
# ==========================================
FRONTEND_URL=http://localhost:3000

# ==========================================
# Rate-Limiting (ITIL Availability Management)
# ==========================================
RATE_LIMIT_MAX=200          # Requêtes max par minute (toutes routes)
RATE_LIMIT_HEAVY_MAX=20     # Requêtes max par minute (generate/sync — routes coûteuses)

# ==========================================
# Cache & Performance (LEAN)
# ==========================================
CACHE_DURATION=30000        # Durée du cache en ms (défaut: 30s)
API_TIMEOUT=10000           # Timeout axios en ms (défaut: 10s)

# ==========================================
# Logging (ITIL Service Management)
# ==========================================
LOG_LEVEL=info              # error | warn | info | debug

# ==========================================
# Auto-Sync Cron — Testmo → GitLab
# Cron: lun-ven 8h-18h toutes les 5 min
# ==========================================
SYNC_TIMEZONE=Europe/Paris  # Timezone IANA (ex: Europe/Paris, UTC, America/New_York)
SYNC_AUTO_RUN_ID=279
SYNC_AUTO_ITERATION_NAME=R10 - run 1
SYNC_AUTO_GITLAB_PROJECT_ID=63
SYNC_AUTO_ENABLED=true
SYNC_AUTO_VERSION=                                # Filtre par champ custom version (optionnel)

# ==========================================
# Sync GitLab → Testmo (mapping projets)
# ==========================================
TESTMO_PROJECT_ID=1
TESTMO_REPOSITORY_ID=1
TESTMO_ROOT_GROUP_ID=4514
TESTMO_GITLAB_INTEGRATION_ID=2
TESTMO_GITLAB_CONNECTION_PROJECT_ID=63

# ==========================================
# Authentification OAuth GitLab
# ==========================================
GITLAB_CLIENT_ID=                                 # ID de l'application OAuth GitLab
GITLAB_CLIENT_SECRET=                             # Secret de l'application OAuth GitLab
BACKEND_URL=http://localhost:3001                 # URL publique du backend (pour le callback OAuth)
JWT_SECRET=                                       # Clé secrète pour signer les JWT (fallback sur ADMIN_API_TOKEN)

# ==========================================
# Notifications Email (SMTP)
# ==========================================
SMTP_HOST=                                        # Ex: smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                                        # Adresse email d'envoi
SMTP_PASS=                                        # Mot de passe ou app-specific password
SMTP_FROM=qa-dashboard@neo-logix.local            # Adresse d'expédition par défaut

# ==========================================
# Monitoring & Sécurité
# ==========================================
SENTRY_DSN=                                       # URL Sentry pour le monitoring d'erreurs
SENTRY_TRACES_SAMPLE_RATE=0.1                     # Taux d'échantillonnage des traces (0.0 - 1.0)
ADMIN_API_TOKEN=                                  # Token pour protéger les endpoints admin (cache/clear, feature-flags...)

# ==========================================
# Audit & Observabilité (P8)
# ==========================================
AUDIT_RETENTION_DAYS=90                           # Rétention des logs d'audit en jours
ALERT_ERROR_RATE_THRESHOLD=5                      # Seuil d'alerte taux d'erreur HTTP (%)
ALERT_MEMORY_THRESHOLD=80                         # Seuil d'alerte mémoire (%)
ALERT_DISK_THRESHOLD=85                           # Seuil d'alerte disque (%)

# ==========================================
# Backup automatisé SQLite (P21)
# ==========================================
BACKUP_DIR=                                       # Répertoire de stockage des backups (défaut: backend/backups)
BACKUP_LOCAL_RETENTION_DAYS=7                     # Rétention des backups locaux en jours

# --- Option A : S3 / MinIO / Spaces (optionnel) ---
BACKUP_S3_BUCKET=                                 # Nom du bucket S3 (optionnel)
BACKUP_S3_REGION=                                 # Région S3 (ex: eu-west-3)
BACKUP_S3_ACCESS_KEY_ID=                          # Clé d'accès AWS/S3
BACKUP_S3_SECRET_ACCESS_KEY=                      # Secret d'accès AWS/S3
BACKUP_S3_ENDPOINT=                               # Endpoint personnalisé (MinIO, DigitalOcean Spaces...) — laisser vide pour AWS
BACKUP_S3_RETENTION_DAYS=30                       # Rétention des backups S3 en jours

# --- Option B : rsync/SSH vers un serveur secondaire (optionnel) ---
BACKUP_RSYNC_ENABLED=false                        # true pour activer le rsync
BACKUP_RSYNC_HOST=                                # IP ou hostname du serveur de backup (ex: backup.mondomaine.fr)
BACKUP_RSYNC_USER=                                # Utilisateur SSH sur le serveur distant
BACKUP_RSYNC_PATH=                                # Chemin distant absolu (ex: /backups/qa-dashboard/)
BACKUP_RSYNC_SSH_KEY=                             # Chemin vers la clé SSH privée (ex: /root/.ssh/backup_ed25519)
BACKUP_RSYNC_PORT=22                              # Port SSH distant
BACKUP_RSYNC_RETENTION_DAYS=30                    # Rétention des backups distants en jours

# ==========================================
# Testmo Browser Automation (Option B — runs manuels)
# ==========================================
# L'API Testmo ne permet pas de créer des runs manuels.
# Ces credentials servent à piloter l'UI via Puppeteer.
TESTMO_UI_USER=                                   # Email du compte Testmo
TESTMO_UI_PASSWORD=                               # Mot de passe du compte Testmo
# Alternative : cookie de session pré-existant
TESTMO_BROWSER_COOKIE=                            # Cookie testmo_session (optionnel)
# Timeouts & sélecteurs (optionnels, valeurs par défaut robustes)
TESTMO_BROWSER_TIMEOUT=30000                      # Timeout Puppeteer (ms)
TESTMO_BROWSER_HEADLESS=true                      # false pour voir le navigateur
TESTMO_BROWSER_IDLE_TIMEOUT_MS=300000             # Fermeture auto du browser après inactivité
TESTMO_BROWSER_SCREENSHOTS=./logs/testmo-browser  # Dossier screenshots debug

# ==========================================
# INSTRUCTIONS GÉNÉRATION DES TOKENS
# ==========================================
# Testmo:
#   1. Avatar (coin droit) > User Profile > API access
#   2. "Generate new API key"
#   3. ⚠️ Copier immédiatement (affiché une seule fois)
#   4. Coller dans TESTMO_TOKEN
#
# GitLab — Token lecture (GITLAB_TOKEN):
#   1. User Settings > Access Tokens
#   2. Scope: read_api
#   3. Coller dans GITLAB_TOKEN
#
# GitLab — Token écriture (GITLAB_WRITE_TOKEN):
#   1. User Settings > Access Tokens
#   2. Scope: api (lecture + écriture)
#   3. Coller dans GITLAB_WRITE_TOKEN
#
# Sécurité production:
#   - Stocker les tokens dans un Secret Manager (Vault, AWS Secrets Manager, etc.)
#   - Faire tourner (rotation) les tokens tous les 90 jours
#   - Ne jamais logger les tokens (le code les masque automatiquement)
