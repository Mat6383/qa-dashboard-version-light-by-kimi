{
  "name": "testmo-dashboard-backend",
  "version": "1.0.0",
  "description": "Backend sécurisé pour dashboard Testmo - ISTQB compliant",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "dev:docker": "nodemon --legacy-watch --ext ts,js,json --exec tsx server.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "(cp -r docs dist/ 2>/dev/null || true) && mkdir -p dist/db && (cp -r db/migrations dist/db/ 2>/dev/null || true) && (cp -r data dist/ 2>/dev/null || true)",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "testmo",
    "dashboard",
    "qa",
    "istqb",
    "lean"
  ],
  "author": "Matou - Neo-Logix QA Lead",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@sentry/node": "^10.49.0",
    "@trpc/server": "^11.17.0",
    "axios": "^1.6.5",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.8",
    "jsonwebtoken": "^9.0.3",
    "marked": "^4.3.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-gitlab2": "^5.0.0",
    "pptxgenjs": "^4.0.1",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.42.0",
    "superjson": "^2.2.6",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/core": "^1.15.32",
    "@swc/jest": "^0.2.39",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
