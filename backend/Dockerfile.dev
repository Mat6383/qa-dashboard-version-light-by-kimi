# syntax=docker/dockerfile:1
# ───────────────────────────────────────────────────────────────────────────────
# Backend — Image de développement (hot-reload)
# Node + outils natifs (better-sqlite3) + Chromium (Puppeteer)
# ───────────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim

WORKDIR /app

ENV NODE_ENV=development
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV DB_DATA_DIR=/app/db-data

# Dépendances système : compilation natif + Chromium runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    chromium \
    ca-certificates \
    fonts-liberation \
    libnss3 \
    libgbm1 \
    libasound2 \
    libxss1 \
    libgtk-3-0 \
    libsqlite3-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Installation des dépendances npm (cache Docker si package*.json inchangé)
COPY package*.json ./
RUN npm install

# Le code source est monté par bind mount en dev
CMD ["npm", "run", "dev:docker"]
